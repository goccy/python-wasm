# wasmify per-project build cache (.o / .a / cache.json) and the installed
# wasi-sdk / tool binaries. Regenerated by `make tools` / `make wasm`.
.wasmify/
.wasmify-bin

# wasm build output.
/wasm/
*.wasm

# wasmify-generated artefacts. The build pipeline regenerates them from
# wasmify.json + the cpython submodule on every run (build.json is captured in
# the build container, so committing it would also bake in host-local paths).
/build.json
/api-spec.json
/proto/
/bridge/

# Phase logs written by the wasmify / wasm2go pipeline.
*.log

# Local scratch binary.
.pgw

# The transpiled Go output is a SEPARATE module (the go-python repo); a go.mod
# named after it must not live here.
/go.mod
/go.sum

# Local agent state.
.claude/

# OS / editor noise.
.DS_Store
