# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# env file
.env

# Local agent state
.claude/

# wasmify per-project build cache (.o / .a / cache.json) and installed toolchain
.wasmify/

# wasmify-generated artefacts (regenerated by `make wasm` from wasmify.json +
# the cpython submodule + the committed bridge sources)
/build.json
/api-spec.json
/proto/python.proto
/bridge/
/build/
/*.wasm
# Generated stdlib zip (built from cpython/Lib by scripts/make-stdlib-zip.py
# during release staging; published as a release asset, not committed).
/python_stdlib.zip
